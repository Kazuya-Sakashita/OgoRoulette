# ============================================================
# OgoRoulette — 環境変数サンプル
# このファイルをコピーして .env.local を作成してください
# cp .env.example .env.local
# ============================================================

# ----------------------------------------------------------
# Supabase（クライアント公開可）
# Supabase ダッシュボード > Settings > API で確認
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ----------------------------------------------------------
# Supabase Service Role（サーバーのみ — 絶対に公開しない）
# LINE 認証の Admin API（ユーザー upsert）に使用
# Supabase ダッシュボード > Settings > API > service_role
# ----------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----------------------------------------------------------
# Prisma / PostgreSQL（サーバーのみ）
# Supabase ダッシュボード > Settings > Database > Connection string
# Transaction pooler (DATABASE_URL) + Direct (DIRECT_URL)
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ----------------------------------------------------------
# LINE Login（サーバーのみ）
# LINE Developers コンソール > プロバイダー > チャネル で確認
# ----------------------------------------------------------
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
# 本番: https://your-domain.com/api/auth/line/callback
# 開発: http://localhost:3000/api/auth/line/callback
LINE_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

# ----------------------------------------------------------
# アプリの公開 URL（サーバーのみ）
# LINE コールバック内でのリダイレクト先 origin として使用
# 本番: https://your-domain.com
# 開発: http://localhost:3000
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------
# ゲストホストトークン署名シークレット（サーバーのみ — 絶対に公開しない）
# ゲストルームのオーナー操作を HMAC-SHA256 で署名・検証するために使用
# 生成例: openssl rand -hex 32
# ----------------------------------------------------------
GUEST_HOST_SECRET=your_guest_host_secret_at_least_32_chars

# ----------------------------------------------------------
# Google OAuth リダイレクト URL（開発環境専用 / 本番では設定しない）
# Supabase の Google OAuth が localhost に返ってこない場合のみ設定
# 本番環境では必ず削除または未設定にすること
# ----------------------------------------------------------
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
